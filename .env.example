# Application
ENV=development
DEBUG=true

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://climbe:climbe@localhost:5432/climbe

# JWT
# Gere um segredo forte com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Admin inicial (criado pela migration de seed da auth-jwt)
ADMIN_EMAIL=admin@climbe.local
ADMIN_PASSWORD=change-me-admin-password

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# CORS (separado por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
